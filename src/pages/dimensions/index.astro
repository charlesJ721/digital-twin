---
import Layout from '../../layouts/Layout.astro';
import dimensions from '../../../data/users/arslonga/dimensions-public.json';

const base = import.meta.env.BASE_URL;
const layers = Object.entries(dimensions.layers).sort(([a], [b]) => Number(a) - Number(b));

// 维度含义速查
const layerDescriptions: Record<string, string> = {
  '1': '人格特质：性格模式、核心驱动力',
  '2': '认知架构：推理风格、决策偏好',
  '3': '价值观与信念：行为选择背后的价值优先级',
  '4': '行为模式：工作节奏、应对方式',
  '5': '知识结构：知识领域、学习方式',
  '6': '社会关系：信任模式、合作偏好',
  '7': '叙事自我：自我认知、人生叙事',
};

// SVG params
const cx = 150, cy = 150, r = 110;
const n = layers.length;
const startAngle = -Math.PI / 2;

function getPoint(i: number, value: number) {
  const angle = startAngle + (2 * Math.PI * i) / n;
  return {
    x: cx + r * (value / 100) * Math.cos(angle),
    y: cy + r * (value / 100) * Math.sin(angle),
    labelX: cx + (r + 22) * Math.cos(angle),
    labelY: cy + (r + 22) * Math.sin(angle),
    angle,
  };
}

const points = layers.map(([, layer], i) => getPoint(i, layer.fill_rate));
const polygonPoints = points.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
const rings = [25, 50, 75, 100];

// Colors
function colorForRate(rate: number): string {
  if (rate >= 70) return 'emerald';
  if (rate >= 50) return 'teal';
  if (rate >= 30) return 'amber';
  return 'red';
}
---

<Layout title="维度雷达图">
  <main class="min-h-screen px-6 py-12 max-w-4xl mx-auto">
    <header class="mb-10">
      <a href={`${base}`} class="text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">← 首页</a>
      <h1 class="text-3xl font-bold mt-4 mb-2">维度雷达图</h1>
      <p class="text-zinc-500 dark:text-zinc-400 max-w-xl">
        七层认知人格维度。越饱满，数字镜像越接近原型。
        每天凌晨自动从 Hermes 会话中提取新洞察。
      </p>
      <div class="flex gap-4 mt-4 text-xs text-zinc-400">
        <span>最后更新：{dimensions.last_extraction ? new Date(dimensions.last_extraction).toLocaleDateString('zh-CN') : '手动回填'}</span>
        <span>已处理 {dimensions.total_sessions_processed} 次会话</span>
      </div>
    </header>

    <!-- Radar Chart -->
    <div class="flex flex-col lg:flex-row gap-8 items-start mb-12">
      <div class="shrink-0 relative group">
        <svg viewBox="0 0 300 300" class="w-[320px] h-[320px]" role="img" aria-label="七层维度雷达图">
          <!-- Grid rings -->
          {rings.map(ring => (
            <polygon
              points={layers.map(([,], i) => {
                const p = getPoint(i, ring);
                return `${p.x.toFixed(1)},${p.y.toFixed(1)}`;
              }).join(' ')}
              fill="none"
              stroke="currentColor"
              class="text-zinc-200 dark:text-zinc-700"
              stroke-width="0.5"
            />
          ))}
          <!-- Axis lines -->
          {points.map(p => (
            <line x1={cx} y1={cy} x2={p.labelX - 15 * Math.cos(p.angle)} y2={p.labelY - 15 * Math.sin(p.angle)}
              stroke="currentColor" class="text-zinc-300 dark:text-zinc-600" stroke-width="0.5" />
          ))}
          <!-- Data polygon -->
          <polygon points={polygonPoints} fill="rgba(16,185,129,0.12)" stroke="rgb(16,185,129)" stroke-width="1.5" />
          <!-- Data dots with tooltip -->
          {points.map((p, i) => (
            <g>
              <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="8" fill="transparent" class="cursor-pointer" />
              <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="3" fill="rgb(16,185,129)" />
              <title>L{layers[i][0]} {layers[i][1].name}：{layers[i][1].fill_rate}%（{layers[i][1].insight_count} 条洞察）</title>
            </g>
          ))}
          <!-- Layer number labels -->
          {points.map((p, i) => (
            <text
              x={p.labelX.toFixed(1)} y={p.labelY.toFixed(1)}
              text-anchor="middle" dominant-baseline="middle"
              class="fill-zinc-500 dark:fill-zinc-400 text-[10px] font-bold"
            >
              L{layers[i][0]}
            </text>
          ))}
        </svg>
      </div>

      <!-- Layer detail list -->
      <div class="flex-1 space-y-3 w-full">
        {layers.map(([id, layer]) => (
          <div class="flex items-center gap-3 p-3 rounded-lg border border-zinc-200 dark:border-zinc-800 hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors">
            <div class={`shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ${
              layer.fill_rate >= 70 ? 'bg-emerald-500/20 text-emerald-600 dark:text-emerald-400' :
              layer.fill_rate >= 50 ? 'bg-teal-500/20 text-teal-600 dark:text-teal-400' :
              layer.fill_rate >= 30 ? 'bg-amber-500/20 text-amber-600 dark:text-amber-400' :
              'bg-red-500/20 text-red-600 dark:text-red-400'
            }`}>
              {id}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium truncate">{layer.name}</span>
                <span class="text-xs text-zinc-400">{layer.fill_rate}%</span>
              </div>
              <div class="w-full h-1.5 rounded-full bg-zinc-100 dark:bg-zinc-800 mt-1">
                <div class={`h-full rounded-full transition-all ${
                  layer.fill_rate >= 70 ? 'bg-emerald-500' :
                  layer.fill_rate >= 50 ? 'bg-teal-500' :
                  layer.fill_rate >= 30 ? 'bg-amber-500' :
                  'bg-red-500'
                }`} style={`width:${layer.fill_rate}%`}></div>
              </div>
              <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-1">
                {layer.insight_count} 条洞察 · {layerDescriptions[id] || ''}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Trend section (if history exists) -->
    {dimensions.history && dimensions.history.length > 1 && (
      <section class="mb-12">
        <h2 class="text-xl font-semibold mb-4">趋势</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left border-collapse">
            <thead>
              <tr class="border-b border-zinc-200 dark:border-zinc-800">
                <th class="py-2 pr-4 text-zinc-400 font-normal">日期</th>
                {layers.map(([id]) => (
                  <th class="py-2 px-2 text-zinc-400 font-normal text-center">L{id}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {dimensions.history.slice().reverse().map((h: any) => (
                <tr class="border-b border-zinc-100 dark:border-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-900/50">
                  <td class="py-2 pr-4 text-zinc-600 dark:text-zinc-300">{new Date(h.date).toLocaleDateString('zh-CN')}</td>
                  {layers.map(([id]) => {
                    const val = h.layers?.[id] ?? 0;
                    const prev = dimensions.history[dimensions.history.indexOf(h) - 1]?.layers?.[id];
                    const delta = prev ? val - prev : 0;
                    return (
                      <td class="py-2 px-2 text-center">
                        <span class={delta > 0 ? 'text-emerald-500' : delta < 0 ? 'text-red-400' : 'text-zinc-400'}>
                          {val}%
                        </span>
                        {delta !== 0 && (
                          <span class={`text-[10px] ml-0.5 ${delta > 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                            {delta > 0 ? '+' : ''}{delta}
                          </span>
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800 flex gap-6 text-sm text-zinc-400">
      <a href={`${base}`} class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">首页</a>
      <a href={`${base}/notes`} class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">笔记</a>
      <a href={`${base}/timeline`} class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">时间线</a>
      <a href={`${base}/tags`} class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">标签</a>
      <span class="text-zinc-300 dark:text-zinc-600">|</span>
      <span class="text-emerald-500 dark:text-emerald-400 font-medium">维度</span>
    </footer>
  </main>
</Layout>

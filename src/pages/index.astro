---
import Layout from '../layouts/Layout.astro';
---

<section class="min-h-screen flex flex-col items-center justify-center text-center p-8">
  <h1 class="text-4xl font-bold mb-4">Digital Twin</h1>
  <p class="text-xl text-gray-500 mb-8 max-w-2xl">
    数字世界的另一个我——将一个人的认知结构与人格特质还原为可交互的数字镜像。
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl">
    <div class="p-6 rounded-lg border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold mb-2">Phase 1</h2>
      <p class="text-gray-500">静态镜像</p>
      <span class="text-sm text-amber-500">进行中</span>
    </div>
    <div class="p-6 rounded-lg border border-gray-200 dark:border-gray-700 opacity-50">
      <h2 class="text-lg font-semibold mb-2">Phase 2</h2>
      <p class="text-gray-500">对话镜像</p>
      <span class="text-sm text-gray-400">待开始</span>
    </div>
    <div class="p-6 rounded-lg border border-gray-200 dark:border-gray-700 opacity-50">
      <h2 class="text-lg font-semibold mb-2">Phase 3</h2>
      <p class="text-gray-500">平台化</p>
      <span class="text-sm text-gray-400">待开始</span>
    </div>
  </div>

  <div class="mt-12 flex gap-4">
    <a href="/notes" class="px-6 py-3 rounded-lg bg-gray-900 text-white dark:bg-white dark:text-gray-900 hover:opacity-90 transition-opacity font-medium">
      浏览笔记 →
    </a>
    <a href="https://github.com/charlesJ721/digital-twin" class="px-6 py-3 rounded-lg border border-gray-300 dark:border-gray-600 hover:border-gray-500 transition-colors">
      GitHub
    </a>
  </div>

  <footer class="mt-16 text-sm text-gray-400">
    ArsLonga · {new Date().getFullYear()}
  </footer>
</section>

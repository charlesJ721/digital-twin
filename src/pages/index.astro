---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../../site.config.json';
const base = import.meta.env.BASE_URL;
const title = siteConfig.title || 'Digital Twin';
const description = siteConfig.description || 'A cloneable digital-twin framework.';
const repoUrl = siteConfig.repo_url || 'https://github.com/charlesJ721/digital-twin';
const displayName = siteConfig.display_name || siteConfig.default_user || 'Digital Twin User';
---

<Layout title={title}>
  <main class="min-h-screen flex flex-col items-center justify-center text-center px-6 py-24">
    <h1 class="text-5xl font-bold tracking-tight mb-4">{title}</h1>
    <p class="text-lg text-zinc-500 dark:text-zinc-400 mb-12 max-w-xl leading-relaxed">
      {description}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl w-full mb-12">
      <div class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 text-left">
        <h2 class="text-sm font-semibold mb-1 text-zinc-900 dark:text-zinc-100">Phase 1</h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">静态镜像</p>
        <span class="text-xs text-amber-600 dark:text-amber-400">进行中</span>
      </div>
      <div class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 opacity-60 text-left">
        <h2 class="text-sm font-semibold mb-1 text-zinc-900 dark:text-zinc-100">Phase 2</h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">对话镜像</p>
        <span class="text-xs text-zinc-400">待开始</span>
      </div>
      <div class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 opacity-60 text-left">
        <h2 class="text-sm font-semibold mb-1 text-zinc-900 dark:text-zinc-100">Phase 3</h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">平台化</p>
        <span class="text-xs text-zinc-400">待开始</span>
      </div>
    </div>

    <div class="flex gap-3">
      <a href={`${base}/notes`} class="px-5 py-2.5 rounded-lg bg-zinc-900 text-white dark:bg-white dark:text-zinc-900 hover:opacity-85 transition-opacity text-sm font-medium">
        浏览笔记 →
      </a>
      <a href={`${base}/dimensions`} class="px-5 py-2.5 rounded-lg border border-emerald-300 dark:border-emerald-700 text-emerald-600 dark:text-emerald-400 hover:border-emerald-400 dark:hover:border-emerald-500 transition-colors text-sm font-medium">
        维度雷达
      </a>
      <a href={repoUrl} class="px-5 py-2.5 rounded-lg border border-zinc-300 dark:border-zinc-700 hover:border-zinc-400 dark:hover:border-zinc-500 transition-colors text-sm">
        GitHub
      </a>
    </div>

    <footer class="mt-20 text-sm text-zinc-400 dark:text-zinc-500">
      {displayName} · {new Date().getFullYear()}
    </footer>
  </main>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const allNotes = await getCollection('notes');
const notes = allNotes
  .filter(n => n.data['dg-publish'] !== false)
  .map(note => {
    const slug = note.id.replace(/^src\/content\/notes\//, '').replace(/\.md$/, '');
    const title = note.data.title || slug.split('/').pop() || slug;
    return { ...note, _slug: slug, _title: title };
  })
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));

// Separate dated and undated
const datedNotes = notes.filter(n => n.data.date);
const undatedNotes = notes.filter(n => !n.data.date);

// Group by year
const byYear = new Map();
for (const note of datedNotes) {
  const year = note.data.date.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year).push(note);
}

const yearOrder = [...byYear.keys()].sort().reverse();

const layerColors = {
  '范式层': 'bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-300',
  '架构层': 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
  '手段层': 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
};
---

<Layout title="时间线">
  <main class="max-w-3xl mx-auto px-6 py-16">
    <a href={`${base}/notes`} class="inline-flex items-center gap-1 text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      返回笔记
    </a>

    <h1 class="text-3xl font-bold mb-2 tracking-tight">时间线</h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-12">{notes.length} 篇笔记 · 按时间排列</p>

    {notes.length === 0 && (
      <p class="py-12 text-center text-zinc-400">还没有笔记</p>
    )}

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-[19px] top-0 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800" aria-hidden="true"></div>

      <div class="space-y-16">
        {yearOrder.map(year => (
          <section>
            {/* Year marker */}
            <div class="flex items-center gap-4 mb-8 -ml-1">
              <div class="w-[40px] h-[40px] rounded-full bg-zinc-900 dark:bg-zinc-100 flex items-center justify-center flex-shrink-0 relative z-10">
                <span class="text-sm font-bold text-white dark:text-zinc-900">{year}</span>
              </div>
              <h2 class="text-xl font-semibold tracking-tight">{year}</h2>
            </div>

            <div class="ml-[19px] pl-8 border-l border-transparent space-y-6">
              {byYear.get(year).map(note => (
                <a
                  href={`${base}/notes/${note._slug}`}
                  class="block relative group"
                >
                  {/* Dot on timeline */}
                  <div class="absolute -left-[29px] top-2 w-[9px] h-[9px] rounded-full bg-zinc-300 dark:bg-zinc-600 group-hover:bg-zinc-500 dark:group-hover:bg-zinc-400 transition-colors ring-4 ring-white dark:ring-zinc-950"></div>
                  
                  <div class="pb-4 pl-0 hover:bg-zinc-50 dark:hover:bg-zinc-800/30 -mx-3 px-3 py-2 rounded-lg transition-colors">
                    <h3 class="font-medium group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">
                      {note._title}
                    </h3>
                    <div class="flex items-center gap-2 mt-1 flex-wrap">
                      <time class="text-sm text-zinc-400 dark:text-zinc-500 tabular-nums">{note.data.date}</time>
                      {note.data.layer && (
                        <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${layerColors[note.data.layer] || ''}`}>
                          {note.data.layer}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>

    {undatedNotes.length > 0 && (
      <section class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
        <h2 class="text-lg font-semibold mb-6 text-zinc-400">时间不详</h2>
        <div class="space-y-3">
          {undatedNotes.map(note => (
            <a href={`${base}/notes/${note._slug}`} class="block py-3 hover:bg-zinc-50 dark:hover:bg-zinc-800/30 -mx-3 px-3 rounded-lg transition-colors">
              <h3 class="font-medium">{note._title}</h3>
              {note.data.layer && (
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium mt-1 inline-block ${layerColors[note.data.layer] || ''}`}>
                  {note.data.layer}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
